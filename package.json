{
  "name": "howard-vox-ai",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 0.0.0.0",
    "server": "node server/index.js",
    "worker:python": "python3 -m uvicorn python_worker.app:app --host 127.0.0.1 --port 8797",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "android:doctor": "node scripts/check-android-build-env.mjs",
    "android:patch-capacitor": "node scripts/patch-capacitor-android-host.mjs",
    "android:prepare-model": "node scripts/prepare-android-model.mjs",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "android:debug": "npm run android:doctor && npm run android:patch-capacitor && npm run android:prepare-model && npm run android:sync && cd android && ./gradlew assembleDebug",
    "apk:debug": "npm run android:debug"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "audio-decode": "^3.8.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "lucide-react": "^1.7.0",
    "multer": "^2.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "wouter": "^3.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.7",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.1"
  }
}
